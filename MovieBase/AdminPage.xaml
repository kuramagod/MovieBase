<Page x:Class="MovieBase.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MovieBase"
      xmlns:Converters="clr-namespace:MovieBase.Сonverters"
      mc:Ignorable="d" 
      Title="Панель администратора" Background="#1E1E1E">

    <Page.Resources>
        <!-- Стиль для кнопок действий -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="#3A3A3A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для DataGrid -->
        <Style x:Key="ModernDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="RowBackground" Value="#1E1E1E"/>
            <Setter Property="AlternatingRowBackground" Value="#252525"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#2A2A2A"/>
                        <Setter Property="Foreground" Value="#CCCCCC"/>
                        <Setter Property="Padding" Value="10,5"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#3A3A3A"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для TabItem -->
        <Style TargetType="TabItem">
            <Setter Property="Header" Value="{Binding Header}"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid>
                            <Border Name="Border" 
                                    Background="{TemplateBinding Background}" 
                                    BorderThickness="0"
                                    CornerRadius="5 5 0 0"
                                    Margin="0 0 2 0">
                                <ContentPresenter x:Name="ContentSite"
                                                  ContentSource="Header"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#2A2A2A"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="Border" Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="Border" Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Converters:ByteArrayToImageConverter x:Key="ByteArrayToImageConverter"/>
        <Converters:TruncateTextConverter  x:Key="TruncateTextConverter"/>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель с поиском -->
        <DockPanel Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <!-- Обновленный SearchBox -->
                <Border Background="#2A2A2A" CornerRadius="25" Height="50" Width="350">
                    <Grid>
                        <TextBox x:Name="SearchBox" 
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="White"
                                FontSize="16"
                                CaretBrush="White"
                                VerticalAlignment="Center"
                                VerticalContentAlignment="Center"
                                Padding="15,0"
                                TextChanged="SearchBox_TextChanged">
                            <TextBox.Resources>
                                <VisualBrush x:Key="HintText" TileMode="None" Stretch="None" AlignmentX="Left">
                                    <VisualBrush.Visual>
                                        <TextBlock Text="Поиск по названию/имени..." 
                                                  Foreground="#808080" 
                                                  FontStyle="Italic"
                                                  FontSize="16"
                                                  VerticalAlignment="Center"/>
                                    </VisualBrush.Visual>
                                </VisualBrush>
                            </TextBox.Resources>
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <Grid>
                                                    <ScrollViewer x:Name="PART_ContentHost" 
                                                                 VerticalAlignment="Center"
                                                                 Margin="15,0"/>
                                                    <TextBlock Text="Поиск по названию/имени..." 
                                                              Foreground="#808080" 
                                                              FontStyle="Italic"
                                                              FontSize="16"
                                                              VerticalAlignment="Center"
                                                              Margin="15,0"
                                                              IsHitTestVisible="False"
                                                              Visibility="Collapsed"
                                                              x:Name="PlaceholderText"/>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="Text" Value="">
                                                        <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Grid>
                </Border>

                <Button Content="+ Добавить запись" Click="Add_Click" 
                        Style="{StaticResource ButtonStyle}" Width="180" Margin="20,0"/>
            </StackPanel>

            <TextBlock Text="АДМИН-ПАНЕЛЬ" VerticalAlignment="Center" HorizontalAlignment="Right" 
                       FontSize="20" FontWeight="Bold" Foreground="#D32F2F"/>
        </DockPanel>

        <!-- TabControl -->
        <TabControl x:Name="AdminTabs" Grid.Row="1" Background="Transparent" BorderThickness="0" 
                    SelectionChanged="AdminTabs_SelectionChanged">

            <!-- Фильмы -->
            <TabItem Header="Фильмы" Tag="Movies">
                <DataGrid x:Name="MoviesGrid" AutoGenerateColumns="False" IsReadOnly="True" 
              Style="{StaticResource ModernDataGrid}" RowHeight="60">
                    <DataGrid.Columns>
                        <!-- ID - 3% -->
                        <DataGridTextColumn Header="ID" Binding="{Binding Movieid}" Width="3*"/>

                        <!-- Обложка - 5% -->
                        <DataGridTemplateColumn Header="Обложка" Width="5*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="#2A2A2A" Width="50" Height="50" CornerRadius="5">
                                        <Image Source="{Binding Cover, Converter={StaticResource ByteArrayToImageConverter}}"
                                   Width="50" Height="50" Stretch="UniformToFill"
                                   Margin="2">
                                            <Image.Style>
                                                <Style TargetType="Image">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Cover}" Value="{x:Null}">
                                                            <Setter Property="Source" Value="/images/no_image.jpg"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Cover}" Value="">
                                                            <Setter Property="Source" Value="/images/no_image.jpg"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Название - 15% -->
                        <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="15*"/>

                        <!-- Описание - 40% (самая широкая) -->
                        <DataGridTemplateColumn Header="Описание" Width="40*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Description, Converter={StaticResource TruncateTextConverter}}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"
                                   ToolTip="{Binding Description}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Год - 5% -->
                        <DataGridTextColumn Header="Год" Binding="{Binding Year}" Width="5*"/>

                        <!-- Жанр - 8% -->
                        <DataGridTextColumn Header="Жанр" Binding="{Binding Genre.Name}" Width="8*"/>

                        <!-- Страна - 8% -->
                        <DataGridTextColumn Header="Страна" Binding="{Binding Contry.Name}" Width="8*"/>

                        <!-- Рейтинг - 5% -->
                        <DataGridTextColumn Header="Рейтинг" Binding="{Binding Rating}" Width="5*"/>

                        <!-- Действия - 6% -->
                        <DataGridTemplateColumn Header="Действия" Width="6*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="✏️" Click="Edit_Click" 
                                    Style="{StaticResource ActionButtonStyle}"
                                    Foreground="#E0E0E0"/>
                                        <Button Content="❌" Click="Delete_Click" 
                                    Style="{StaticResource ActionButtonStyle}" 
                                    Foreground="#D32F2F"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- Пользователи -->
            <TabItem Header="Пользователи" Tag="Users">
                <DataGrid x:Name="UsersGrid" AutoGenerateColumns="False" IsReadOnly="True" 
                          Style="{StaticResource ModernDataGrid}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Userid}" Width="50"/>
                        <DataGridTextColumn Header="Логин" Binding="{Binding Username}" Width="*"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
                        <DataGridTextColumn Header="Роль" Binding="{Binding Role.Name}" Width="100"/>
                        <DataGridTemplateColumn Header="Действия" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="✏️" Click="Edit_Click" 
                                                Style="{StaticResource ActionButtonStyle}"
                                                Foreground="#E0E0E0"/>
                                        <Button Content="❌" Click="Delete_Click" 
                                                Style="{StaticResource ActionButtonStyle}" 
                                                Foreground="#D32F2F"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- Рецензии -->
            <TabItem Header="Рецензии" Tag="Reviews">
                <DataGrid x:Name="ReviewsGrid" AutoGenerateColumns="False" IsReadOnly="True" 
                          Style="{StaticResource ModernDataGrid}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Фильм" Binding="{Binding Movie.Title}" Width="*"/>
                        <DataGridTextColumn Header="Автор" Binding="{Binding User.Username}" Width="120"/>
                        <DataGridTextColumn Header="Заголовок" Binding="{Binding Title}" Width="*"/>
                        <DataGridTextColumn Header="Оценка" Binding="{Binding Rating}" Width="70"/>
                        <DataGridTextColumn Header="Дата" Binding="{Binding Date, StringFormat=\{0:dd.MM.yyyy\}}" Width="100"/>
                        <DataGridTemplateColumn Header="Действия" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="✏️" Click="Edit_Click" 
                                                Style="{StaticResource ActionButtonStyle}"
                                                Foreground="#E0E0E0"/>
                                        <Button Content="❌" Click="Delete_Click" 
                                                Style="{StaticResource ActionButtonStyle}" 
                                                Foreground="#D32F2F"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- Жанры -->
            <TabItem Header="Жанры" Tag="Genres">
                <DataGrid x:Name="GenresGrid" AutoGenerateColumns="False" IsReadOnly="True" 
                          Style="{StaticResource ModernDataGrid}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Genreid}" Width="70"/>
                        <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                        <DataGridTemplateColumn Header="Действия" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="✏️" Click="Edit_Click" 
                                                Style="{StaticResource ActionButtonStyle}"
                                                Foreground="#E0E0E0"/>
                                        <Button Content="❌" Click="Delete_Click" 
                                                Style="{StaticResource ActionButtonStyle}" 
                                                Foreground="#D32F2F"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- Страны -->
            <TabItem Header="Страны" Tag="Countries">
                <DataGrid x:Name="CountriesGrid" AutoGenerateColumns="False" IsReadOnly="True" 
                          Style="{StaticResource ModernDataGrid}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Contryid}" Width="70"/>
                        <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                        <DataGridTemplateColumn Header="Действия" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="✏️" Click="Edit_Click" 
                                                Style="{StaticResource ActionButtonStyle}"
                                                Foreground="#E0E0E0"/>
                                        <Button Content="❌" Click="Delete_Click" 
                                                Style="{StaticResource ActionButtonStyle}" 
                                                Foreground="#D32F2F"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- Роли -->
            <TabItem Header="Роли" Tag="Roles">
                <DataGrid x:Name="RolesGrid" AutoGenerateColumns="False" IsReadOnly="True" 
                          Style="{StaticResource ModernDataGrid}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Roleid}" Width="70"/>
                        <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                        <DataGridTemplateColumn Header="Действия" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="✏️" Click="Edit_Click" 
                                                Style="{StaticResource ActionButtonStyle}"
                                                Foreground="#E0E0E0"/>
                                        <Button Content="❌" Click="Delete_Click" 
                                                Style="{StaticResource ActionButtonStyle}" 
                                                Foreground="#D32F2F"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- Избранное -->
            <TabItem Header="Избранное" Tag="Favorites">
                <DataGrid x:Name="FavoritesGrid" AutoGenerateColumns="False" IsReadOnly="True" 
                          Style="{StaticResource ModernDataGrid}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Favoriteid}" Width="50"/>
                        <DataGridTextColumn Header="Пользователь" Binding="{Binding User.Username}" Width="*"/>
                        <DataGridTextColumn Header="Фильм" Binding="{Binding Movie.Title}" Width="*"/>
                        <DataGridTextColumn Header="Дата добавления" Binding="{Binding Date, StringFormat=\{0:dd.MM.yyyy\}}" Width="150"/>
                        <DataGridTemplateColumn Header="Действия" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="❌" Click="Delete_Click" 
                                                Style="{StaticResource ActionButtonStyle}" 
                                                Foreground="#D32F2F"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>