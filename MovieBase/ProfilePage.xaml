<Page x:Class="MovieBase.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MovieBase"
      mc:Ignorable="d" 
      Title="Профиль"
      Background="#121212"
      Foreground="White">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="800">

            <Border Width="180" Height="180" Background="#1E1E1E" CornerRadius="90" Margin="0,0,0,25">
                <Grid>
                    <Image Source="/images/profile.png" Width="100" Opacity="0.8"/>
                    <Border Background="#D32F2F" CornerRadius="12" Padding="15,5" 
                            VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,-10">
                        <TextBlock x:Name="RoleTxt" Text="ПОЛЬЗОВАТЕЛЬ" FontSize="14" FontWeight="Bold"/>
                    </Border>
                </Grid>
            </Border>

            <TextBlock x:Name="UsernameTxt" Text="User_Name" FontSize="48" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock x:Name="EmailTxt" Text="user@example.com" FontSize="20" Foreground="#9E9E9E" HorizontalAlignment="Center" Margin="0,5,0,40"/>

            <UniformGrid Columns="3" Margin="0,0,0,60">
                <Border Background="#1E1E1E" CornerRadius="20" Margin="15" Padding="30">
                    <StackPanel>
                        <TextBlock Text="Рецензий" Foreground="#9E9E9E" FontSize="18" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="ReviewsCountTxt" Text="0" FontSize="42" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="#1E1E1E" CornerRadius="20" Margin="15" Padding="30">
                    <StackPanel>
                        <TextBlock Text="В избранном" Foreground="#9E9E9E" FontSize="18" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="FavoritesCountTxt" Text="0" FontSize="42" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,0" Foreground="#D32F2F"/>
                    </StackPanel>
                </Border>

                <Border Background="#1E1E1E" CornerRadius="20" Margin="15" Padding="30">
                    <StackPanel>
                        <TextBlock Text="Средний балл" Foreground="#9E9E9E" FontSize="18" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="AvgRatingTxt" Text="0.0" FontSize="42" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,0" Foreground="#FFC107"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Button Content="Выйти из системы" 
                    Background="#D32F2F" 
                    Foreground="White" 
                    Height="65" 
                    Width="300"
                    FontSize="20"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="Logout_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="15"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Page>
