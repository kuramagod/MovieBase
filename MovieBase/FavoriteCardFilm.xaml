<UserControl x:Class="MovieBase.FavoriteCardFilm"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MovieBase"
             mc:Ignorable="d" 
             Height="300" Width="200">
    <Border Background="#1E1E1E" CornerRadius="12" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Image Grid.Row="0" Source="{Binding Movie.Cover}" Stretch="UniformToFill"/>

            <Border HorizontalAlignment="Right" 
                    VerticalAlignment="Top" 
                    Margin="10" 
                    Padding="6,3" 
                    Background="#CC121212" 
                    CornerRadius="6">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="★" 
                               Foreground="{Binding RatingColor}" 
                               FontSize="14" 
                               Margin="0,0,3,0"/>
                    <TextBlock Text="{Binding UserRatingDisplay}" 
                               Foreground="{Binding RatingColor}" 
                               FontSize="14" 
                               FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Background="#2A2A2A" Padding="12">
                <StackPanel>
                    <TextBlock Text="{Binding Movie.Title}" Foreground="White" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <TextBlock Text="Добавлено: " Foreground="#9E9E9E" FontSize="12"/>
                        <TextBlock Text="{Binding Favorite.Date, StringFormat='{}{0:dd.MM.yyyy}'}" Foreground="#9E9E9E" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>