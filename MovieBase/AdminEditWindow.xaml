<Window x:Class="MovieBase.AdminEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MovieBase"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="Редактирование записи" Height="Auto" Width="450" 
        SizeToContent="Height" WindowStartupLocation="CenterScreen"
        Background="#1E1E1E" Foreground="White">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/styles/ScrollStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Стиль для текстовых полей -->
            <Style x:Key="ModernTextBox" TargetType="TextBox">
                <Setter Property="Height" Value="40"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Padding" Value="12,0"/>
                <Setter Property="Background" Value="#2A2A2A"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderBrush" Value="#3A3A3A"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="CaretBrush" Value="#D32F2F"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5">
                                <ScrollViewer x:Name="PART_ContentHost" 
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="#D32F2F"/>
                                </Trigger>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter Property="BorderBrush" Value="#D32F2F"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Стиль для многострочного текстового поля (textarea) -->
            <Style x:Key="MultilineTextBox" TargetType="TextBox" BasedOn="{StaticResource ModernTextBox}">
                <Setter Property="Height" Value="120"/>
                <Setter Property="VerticalContentAlignment" Value="Top"/>
                <Setter Property="Padding" Value="12,8"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
                <Setter Property="AcceptsReturn" Value="True"/>
                <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            </Style>

            <!-- Стиль для заблокированных текстовых полей -->
            <Style x:Key="DisabledTextBox" TargetType="TextBox" BasedOn="{StaticResource ModernTextBox}">
                <Setter Property="Background" Value="#1E1E1E"/>
                <Setter Property="Foreground" Value="#666666"/>
                <Setter Property="BorderBrush" Value="#2A2A2A"/>
                <Setter Property="IsEnabled" Value="False"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="BorderBrush" Value="#2A2A2A"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Стиль для ComboBox -->
            <Style x:Key="ModernComboBox" TargetType="ComboBox">
                <Setter Property="Height" Value="40"/>
                <Setter Property="Background" Value="#2A2A2A"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderBrush" Value="#3A3A3A"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Padding" Value="12,0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid>
                                <ToggleButton x:Name="ToggleButton" 
                                  BorderBrush="{TemplateBinding BorderBrush}" 
                                  BorderThickness="{TemplateBinding BorderThickness}" 
                                  Background="{TemplateBinding Background}" 
                                  Grid.ColumnSpan="2" 
                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" 
                                  Focusable="false">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="border" 
                                        Background="{TemplateBinding Background}" 
                                        BorderBrush="{TemplateBinding BorderBrush}" 
                                        BorderThickness="{TemplateBinding BorderThickness}" 
                                        CornerRadius="5"/>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="true">
                                                    <Setter TargetName="border" Property="BorderBrush" Value="#D32F2F"/>
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="true">
                                                    <Setter TargetName="border" Property="BorderBrush" Value="#D32F2F"/>
                                                    <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>

                                <Grid Margin="{TemplateBinding Padding}" IsHitTestVisible="False">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <ContentPresenter x:Name="contentPresenter" 
                                          Content="{TemplateBinding SelectionBoxItem}" 
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" 
                                          ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}" 
                                          VerticalAlignment="Center" 
                                          HorizontalAlignment="Left"/>

                                    <TextBlock x:Name="PlaceholderText" 
                                   Text="{TemplateBinding Tag}" 
                                   Foreground="#808080" 
                                   FontStyle="Italic" 
                                   VerticalAlignment="Center" 
                                   Visibility="Collapsed"/>

                                    <Path x:Name="arrow" 
                              Grid.Column="1" 
                              Data="M0,0 L5,5 L10,0" 
                              Fill="White" 
                              Width="10" Height="5" 
                              Margin="10,0,0,0" 
                              Stretch="Fill" 
                              VerticalAlignment="Center"/>
                                </Grid>

                                <Popup x:Name="PART_Popup" 
                           AllowsTransparency="true" 
                           Grid.ColumnSpan="2" 
                           IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}" 
                           Placement="Bottom" 
                           PopupAnimation="Slide"
                           VerticalOffset="5">
                                    <Border x:Name="dropDownBorder" 
                                Background="#2A2A2A" 
                                BorderBrush="#3A3A3A" 
                                BorderThickness="1" 
                                CornerRadius="5" 
                                MaxHeight="200"
                                Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                        <ScrollViewer x:Name="DropDownScrollViewer">
                                            <ItemsPresenter x:Name="ItemsPresenter" KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="HasItems" Value="false">
                                    <Setter TargetName="dropDownBorder" Property="Height" Value="95"/>
                                </Trigger>
                                <Trigger Property="SelectedItem" Value="{x:Null}">
                                    <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="contentPresenter" Property="Visibility" Value="Collapsed"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            
            <!-- Стиль для предметов ComboBox -->
            <Style x:Key="ModernComboBoxItem" TargetType="ComboBoxItem">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Height" Value="35"/>
                <Setter Property="Padding" Value="12,0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBoxItem">
                            <Border x:Name="ItemBorder" 
                        Background="{TemplateBinding Background}" 
                        Padding="{TemplateBinding Padding}"
                        SnapsToDevicePixels="True">
                                <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#3A3A3A"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#D32F2F"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Стиль для кнопки выбора файла -->
            <Style x:Key="FileButtonStyle" TargetType="Button">
                <Setter Property="Height" Value="40"/>
                <Setter Property="Width" Value="120"/>
                <Setter Property="Background" Value="#3A3A3A"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="#4A4A4A"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#4A4A4A"/>
                        <Setter Property="BorderBrush" Value="#D32F2F"/>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Background" Value="#2A2A2A"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Стиль для заголовков полей -->
            <Style x:Key="FieldHeaderStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#CCCCCC"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin" Value="0,15,0,5"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>

            <!-- Стиль для кнопок -->
            <Style x:Key="DialogButtonStyle" TargetType="Button">
                <Setter Property="Height" Value="40"/>
                <Setter Property="Width" Value="100"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Стиль для кнопки "Сохранить" -->
            <Style x:Key="SaveButtonStyle" TargetType="Button" BasedOn="{StaticResource DialogButtonStyle}">
                <Setter Property="Background" Value="#D32F2F"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#B71C1C"/>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Background" Value="#8B0000"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Стиль для кнопки "Отмена" -->
            <Style x:Key="CancelButtonStyle" TargetType="Button" BasedOn="{StaticResource DialogButtonStyle}">
                <Setter Property="Background" Value="#3A3A3A"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="#4A4A4A"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#4A4A4A"/>
                        <Setter Property="BorderBrush" Value="#D32F2F"/>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Background" Value="#2A2A2A"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Стиль для текста с информацией о файле -->
            <Style x:Key="FileInfoTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#808080"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontStyle" Value="Italic"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="10,0,0,0"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock x:Name="TitleText" 
                   Text="Редактирование" 
                   FontSize="24" 
                   FontWeight="Bold" 
                   Foreground="#D32F2F"
                   Margin="0,0,0,25"/>

        <!-- Контейнер с полями -->
        <ScrollViewer Grid.Row="1" 
                      MaxHeight="600" 
                      VerticalScrollBarVisibility="Auto"
                      Margin="0,0,-10,0">
            <StackPanel x:Name="FieldsContainer" 
                        Margin="0,0,10,0">
                <!-- Поля будут добавляться динамически -->
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,25,0,0">
            <Button Content="Отмена" 
                    Style="{StaticResource CancelButtonStyle}"
                    Click="Cancel_Click" 
                    Margin="0,0,10,0"/>
            <Button Content="Сохранить" 
                    Style="{StaticResource SaveButtonStyle}"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>